{
    "expo": {
        "name": "FadeUp",
        "slug": "fadeup",
        "version": "1.0.0",
        "orientation": "portrait",
        "scheme": "fadeup",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0A0A0A"
        },
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.fadeup.app",
            "infoPlist": {
                "NSCameraUsageDescription": "FadeUp needs camera access for profile photos.",
                "NSPhotoLibraryUsageDescription": "FadeUp needs photo library access for profile photos.",
                "NSUserNotificationsUsageDescription": "FadeUp sends appointment reminders."
            }
        },
        "android": {
            "package": "com.abhinav.fadeup",
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0A0A0A"
            },
            "googleServicesFile": "./google-services.json",
            "permissions": [
                "CAMERA",
                "READ_EXTERNAL_STORAGE",
                "RECEIVE_BOOT_COMPLETED",
                "VIBRATE",
                "POST_NOTIFICATIONS"
            ]
        },
        "plugins": [
            "expo-router",
            "expo-font",
            "expo-secure-store",
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification-icon.png",
                    "color": "#C8A96E"
                }
            ],
            [
                "expo-camera",
                {
                    "cameraPermission": "FadeUp needs camera access."
                }
            ],
            [
                "expo-image-picker",
                {
                    "photosPermission": "FadeUp needs photos access."
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}