# FadeUp Environment Configuration
# Copy this file to .env and fill in your Firebase configuration

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Services Configuration
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
EXPO_PUBLIC_GOOGLE_SIGNIN_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_SIGNIN_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_SIGNIN_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Expo Configuration  
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id

# App Configuration
EXPO_PUBLIC_APP_NAME=FadeUp
EXPO_PUBLIC_APP_VERSION=1.0.0

# Development Configuration
EXPO_PUBLIC_API_BASE_URL=https://us-central1-your_project_id.cloudfunctions.net
EXPO_PUBLIC_ENVIRONMENT=development

# Instructions:
# 1. Get your Google OAuth client IDs from Google Cloud Console
# 2. The iOS client ID should look like: 123456789-abcd1234.apps.googleusercontent.com  
# 3. Replace "your-ios-client-id.apps.googleusercontent.com" with your actual iOS client ID
# 4. Create your .env file: cp .env.example .env
# 5. Fill in all the actual values in your .env file