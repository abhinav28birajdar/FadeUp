rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isBarberOrOwner() {
      return getUserRole() in ['barber', 'shop_owner'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId
        && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isBarberOrOwner() || request.resource.data.ownerId == request.auth.uid);
      allow update: if isAuthenticated()
        && (resource.data.ownerId == request.auth.uid || isAdmin())
        && (isAdmin() || !('isApproved' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /barbers/{barberId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid
            || resource.data.barberId == request.auth.uid
            || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid
            || resource.data.barberId == request.auth.uid
            || isAdmin());
    }

    match /queue/{entryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /chatRooms/{roomId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds;
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read, update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    match /earnings/{earningId} {
      allow read: if isAuthenticated()
        && (resource.data.barberId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated();
    }

    match /inventory/{itemId} {
      allow read, write: if isAuthenticated();
    }
  }
}
