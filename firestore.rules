rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isBarberOrOwner() {
      return isAuthenticated() && getUserRole() in ['barber', 'shop_owner'];
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId)
        && request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'role'])
        && request.resource.data.uid == userId;
      allow update: if isAuthenticated() && isOwner(userId)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();

      // Per-user notification subcollection
      match /notifications/{notifId} {
        allow read, update, delete: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated();
      }
    }

    // ── Shops ──────────────────────────────────────────────────────────────────
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && (isBarberOrOwner() || isAdmin())
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerId', 'name']);
      allow update: if isAuthenticated()
        && (resource.data.ownerId == request.auth.uid || isAdmin())
        && (isAdmin() || !('isApproved' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }

    // ── Services ───────────────────────────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isBarberOrOwner() || isAdmin();
      allow update, delete: if isAuthenticated()
        && (isAdmin() || (isBarberOrOwner()
          && get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid));
    }

    // ── Barbers ────────────────────────────────────────────────────────────────
    match /barbers/{barberId} {
      allow read: if true;
      allow create: if isBarberOrOwner() || isAdmin();
      allow update, delete: if isAuthenticated()
        && (isAdmin() || resource.data.userId == request.auth.uid
          || get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid);
    }

    // ── Bookings ───────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid
            || resource.data.barberId == request.auth.uid
            || get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid
            || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.keys().hasAll(['customerId', 'shopId', 'barberId', 'serviceId', 'scheduledAt', 'status']);
      allow update: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid
            || resource.data.barberId == request.auth.uid
            || get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Queue ──────────────────────────────────────────────────────────────────
    match /queue/{entryId} {
      allow read: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid
            || resource.data.barberId == request.auth.uid
            || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.barberId == request.auth.uid
            || get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.customerId == request.auth.uid);
    }

    // ── Chat Rooms ─────────────────────────────────────────────────────────────
    match /chatRooms/{roomId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds;
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Reviews ────────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.keys().hasAll(['bookingId', 'shopId', 'rating', 'customerId']);
      allow update, delete: if isAdmin();
    }

    // ── Earnings ───────────────────────────────────────────────────────────────
    match /earnings/{earningId} {
      allow read: if isAuthenticated()
        && (resource.data.barberId == request.auth.uid
            || get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid
            || isAdmin());
      allow create: if isAuthenticated()
        && (resource.data.barberId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ── Inventory ──────────────────────────────────────────────────────────────
    match /inventory/{itemId} {
      allow read: if isAuthenticated()
        && (isBarberOrOwner() || isAdmin());
      allow create, update: if isAuthenticated()
        && (isBarberOrOwner() || isAdmin())
        && get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid;
      allow delete: if isAdmin()
        || (isAuthenticated() && isBarberOrOwner()
          && get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid);
    }
  }
}
